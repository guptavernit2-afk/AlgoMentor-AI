# =============================================================================
# AlgoMentor AI — Environment Variables Template
# =============================================================================
# Copy this file to `.env` in the same directory:
#
#     cp backend/.env.example backend/.env
#
# Then fill in your real values.
# NEVER commit `.env` — it is listed in .gitignore.
# =============================================================================


# ---------------------------------------------------------------------------
# Storage backend
# ---------------------------------------------------------------------------
# Set to "memory" (default) to keep using the current in-memory store.
# Set to "postgres" to enable the Supabase PostgreSQL connection.
# Leave this as "memory" until the persistence migration is deliberately
# enabled — changing it before the migration is done will break the API.
STORAGE_BACKEND=memory


# ---------------------------------------------------------------------------
# Supabase Session Pooler connection parameters
# ---------------------------------------------------------------------------
# Obtain these from your Supabase project:
#   Dashboard → your project → Connect (top toolbar)
#   → Session Pooler → View parameters
#
# Using the Session Pooler (port 5432) is recommended for local development
# because direct database connections require IPv6, which some local
# network environments do not support.
#
DB_HOST=your-session-pooler-host
DB_PORT=5432
DB_NAME=postgres
DB_USER=your-session-pooler-user


# ---------------------------------------------------------------------------
# Database password
# ---------------------------------------------------------------------------
# This is the database password you created when setting up the Supabase
# project (Dashboard → Project Settings → Database → Database password).
# It is NOT the anon/service-role API key.
#
DB_PASSWORD=your-database-password


# ---------------------------------------------------------------------------
# SSL mode
# ---------------------------------------------------------------------------
# Always keep this as "require" for Supabase connections.
# Changing it to "disable" is a security risk.
#
DB_SSLMODE=require
